{
	"name": "chaos-board",
	"version": "0.3.1",
	"private": true,
	"license": "FSL-1.1-ALv2",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"package": "./scripts/package.sh",
		"package:unsigned": "./scripts/package.sh --no-sign",
		"release": "bun run package && bun scripts/upload-to-github.cjs",
		"test": "bun test",
		"test:updater": "bun test src/main/updater/github-release-fetcher.test.ts && bun test src/main/updater/downloader.test.ts && bun test src/main/updater/update-manager.test.ts",
		"postinstall": "electron-rebuild -f -w node-pty"
	},
	"build": {
		"appId": "com.chaos-board.desktop",
		"productName": "Chaos Board",
		"publish": [
			{
				"provider": "github",
				"owner": "collaborator-ai",
				"repo": "collab-public"
			}
		],
		"directories": {
			"output": "dist"
		},
		"files": [
			{
				"from": "out",
				"to": "out",
				"filter": [
					"**/*"
				]
			},
			"package.json",
			"NOTICE"
		],
		"extraResources": [
			{
				"from": "resources/tmux.conf",
				"to": "tmux.conf"
			},
			{
				"from": "resources/terminfo",
				"to": "terminfo"
			}
		],
		"mac": {
			"category": "public.app-category.productivity",
			"hardenedRuntime": false,
			"gatekeeperAssess": false,
			"notarize": false,
			"fileAssociations": [
				{
					"ext": [
						"md",
						"mdx",
						"markdown",
						"txt"
					],
					"name": "Text Document",
					"role": "Editor"
				}
			],
			"target": [
				{
					"target": "zip",
					"arch": "arm64"
				}
			]
		}
	},
	"dependencies": {
		"@blocknote/core": "0.47.0",
		"@blocknote/mantine": "0.47.0",
		"@blocknote/react": "0.47.0",
		"@lezer/common": "^1.5.1",
		"@lezer/python": "^1.1.18",
		"@parcel/watcher": "2.5.6",
		"@phosphor-icons/react": "2.1.7",
		"@posthog/react": "^1.8.2",
		"@postlight/parser": "^2.2.3",
		"@tiptap/core": "3.22.2",
		"@tiptap/extension-typography": "3.22.2",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-unicode11": "^0.9.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "2.1.1",
		"d3": "7.9.0",
		"dependency-cruiser": "^17.3.8",
		"electron-updater": "6.8.3",
		"front-matter": "4.0.2",
		"ignore": "7.0.5",
		"katex": "0.16.33",
		"lucide-react": "0.576.0",
		"monaco-editor": "^0.55.1",
		"node-pty": "^1.1.0",
		"posthog-js": "^1.359.1",
		"posthog-node": "^5.28.0",
		"react-markdown": "10.1.0",
		"rehype-katex": "7.0.1",
		"rehype-raw": "7.0.0",
		"remark-breaks": "4.0.0",
		"remark-gfm": "4.0.1",
		"remark-math": "6.0.0",
		"sharp": "0.34.5",
		"streamdown": "2.3.0",
		"tailwind-merge": "3.5.0",
		"typescript": "5.9.3",
		"use-stick-to-bottom": "1.1.3"
	},
	"devDependencies": {
		"@electron/notarize": "2.5.0",
		"@electron/rebuild": "^4.0.3",
		"@octokit/rest": "22.0.1",
		"@tailwindcss/vite": "4.2.0",
		"@types/d3": "7.4.3",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.4",
		"app-builder-bin": "4.2.0",
		"electron": "40.6.0",
		"electron-builder": "26.8.1",
		"electron-vite": "5.0.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwindcss": "4.2.0"
	}
}